*.py[cod]
*.pyo

# Jupyter checkpoint
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Virtual environment
venv/
env/
.env/

# Editor dan OS
.vscode/
.idea/
*.DS_Store
Thumbs.db

